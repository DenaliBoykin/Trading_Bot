KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret_base64
OPENAI_API_KEY=your_openai_api_key

# Pairs are Kraken naming (e.g., XXBTZUSD or XETHZUSD)
TRADE_PAIRS=XXBTZUSD,XETHZUSD

# Safety defaults
MAX_TRADE_USD=200
MAX_TRADES_PER_HOUR=5
MAX_DAILY_LOSS_PCT=15
DAILY_PROFIT_TARGET_PCT=30
RISK_REWARD_MIN=3
STOP_LOSS_PCT=1.0
TAKE_PROFIT_PCT=3.0
DRY_RUN=true
